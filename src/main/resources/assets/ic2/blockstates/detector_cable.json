{
	"multipart": [
		{
			"apply": {
				"model": "ic2:block/cable/detector_core"
			},
			"when": {
				"active": "false"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_core_active"
			},
			"when": {
				"active": "true"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side",
				"uvlock": true
			},
			"when": {
				"north": "true",
				"active": "false"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side",
				"uvlock": true,
				"y": 90
			},
			"when": {
				"east": "true",
				"active": "false"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side",
				"uvlock": true,
				"y": 180
			},
			"when": {
				"south": "true",
				"active": "false"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side",
				"uvlock": true,
				"y": 270
			},
			"when": {
				"west": "true",
				"active": "false"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side",
				"uvlock": true,
				"x": -90
			},
			"when": {
				"up": "true",
				"active": "false"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side",
				"uvlock": true,
				"x": 90
			},
			"when": {
				"down": "true",
				"active": "false"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side_active",
				"uvlock": true
			},
			"when": {
				"north": "true",
				"active": "true"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side_active",
				"uvlock": true,
				"y": 90
			},
			"when": {
				"east": "true",
				"active": "true"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side_active",
				"uvlock": true,
				"y": 180
			},
			"when": {
				"south": "true",
				"active": "true"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side_active",
				"uvlock": true,
				"y": 270
			},
			"when": {
				"west": "true",
				"active": "true"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side_active",
				"uvlock": true,
				"x": -90
			},
			"when": {
				"up": "true",
				"active": "true"
			}
		},
		{
			"apply": {
				"model": "ic2:block/cable/detector_side_active",
				"uvlock": true,
				"x": 90
			},
			"when": {
				"down": "true",
				"active": "true"
			}
		}
	]
}