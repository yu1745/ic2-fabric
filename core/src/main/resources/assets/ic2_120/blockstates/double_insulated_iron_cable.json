{
  "multipart": [
    {
      "apply": {
        "model": "ic2:block/cable/iron_2_core_white"
      }
    },
    {
      "apply": {
        "model": "ic2:block/cable/iron_2_side_white",
        "uvlock": true
      },
      "when": { "north": "true" }
    },
    {
      "apply": {
        "model": "ic2:block/cable/iron_2_side_white",
        "uvlock": true,
        "y": 90
      },
      "when": { "east": "true" }
    },
    {
      "apply": {
        "model": "ic2:block/cable/iron_2_side_white",
        "uvlock": true,
        "y": 180
      },
      "when": { "south": "true" }
    },
    {
      "apply": {
        "model": "ic2:block/cable/iron_2_side_white",
        "uvlock": true,
        "y": 270
      },
      "when": { "west": "true" }
    },
    {
      "apply": {
        "model": "ic2:block/cable/iron_2_side_white",
        "uvlock": true,
        "x": -90
      },
      "when": { "up": "true" }
    },
    {
      "apply": {
        "model": "ic2:block/cable/iron_2_side_white",
        "uvlock": true,
        "x": 90
      },
      "when": { "down": "true" }
    }
  ]
}
